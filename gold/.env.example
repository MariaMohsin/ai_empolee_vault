# AI Employee - Gold Tier Environment Variables
# Copy this file to .env and fill in your real values

# Gmail (SMTP)
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password

# LinkedIn
LINKEDIN_EMAIL=your_email@linkedin.com
LINKEDIN_PASSWORD=your_linkedin_password

# Twitter / X API (https://developer.twitter.com)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# Meta Graph API - Facebook + Instagram (https://developers.facebook.com)
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_IG_USER_ID=
META_IG_ACCESS_TOKEN=

# Odoo (local self-hosted)
ODOO_URL=http://localhost:8069
ODOO_DB=mycompany
ODOO_USERNAME=admin
ODOO_PASSWORD=admin
